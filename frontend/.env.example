# Environment Variables Template
# Copy this file to .env.development or .env.production and update values

# Backend API URL
# Development: http://localhost:8081
# Production: https://your-backend-url.onrender.com
VITE_API_BASE_URL=http://localhost:8081

# Shared DriveShop login (maps to the VITE_SHARED_ADMIN_EMAIL admin account)
VITE_AUTH_USERNAME=driveshop
VITE_AUTH_PASSWORD=scheduler2025
VITE_SHARED_ADMIN_EMAIL=driveshop@driveshop.com

# Supabase (per-user login). Anon key is public / safe for the browser.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
